{
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },

    //default Flask Port
    "forwardPorts": [5000],

    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.vscode-pylance",
                "ms-python.python",
                "ms-python.debugpy",
                "ms-python.mypy-type-checker",
                "charliermarsh.ruff"
            ],
            "settings": {
                "[python]": {
                    "editor.formatOnSave": true,
                    "editor.defaultFormatter": "charliermarsh.ruff"
                }
            }
        }
    }
}